# Database Configuration
# For local development, use localhost
# For Render production, use Supabase direct connection (port 5432, NOT pooler on port 6543)
# Render's persistent container uses direct connections, not pooling
# Get from Supabase: Settings → Database → Connection string → URI mode
# Direct URL format: postgresql://user:password@db.<project>.supabase.co:5432/postgres
# NOTE: Render auto-injects DATABASE_URL if using Render PostgreSQL service
DATABASE_URL=postgresql://user:password@localhost:5432/devarena

# JWT Configuration
JWT_SECRET=your-secret-key-here-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# Server Configuration
# NOTE: PORT is auto-injected by Render - do not manually set in Render environment
PORT=3000
# For Render production, set these to your Render domain
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# Logging Configuration
LOG_LEVEL=info

# OAuth Configuration
# For Render production:
# - Update Google OAuth redirect URI: https://devarena.onrender.com/api/auth/oauth/google/callback
# - Update GitHub OAuth callback URL: https://devarena.onrender.com/api/auth/oauth/github/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# External API Configuration - Kontests.net
KONTESTS_API_URL=https://kontests.net/api/v1/all

# External API Configuration - CLIST.by
CLIST_API_URL=https://clist.by/api/v2/contest/
CLIST_API_KEY=your-clist-api-key

# External API Configuration - Kaggle
KAGGLE_API_KEY=your-kaggle-api-key
KAGGLE_USERNAME=your-kaggle-username

# Data Sync Configuration
SYNC_SCHEDULE=0 */6 * * *
SYNC_TIMEOUT=30000
SYNC_RETRIES=3

# Node Environment
NODE_ENV=development
