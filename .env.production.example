# Production database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/devarena
DB_POOL_SIZE=20

# Security
JWT_SECRET=replace-with-a-secure-32-character-secret
JWT_EXPIRES_IN=7d

# Server
PORT=3000
CORS_ORIGIN=https://your-frontend-domain.example.com
NODE_ENV=production

# Upstream competition APIs
KONTESTS_API_URL=https://kontests.net/api/v1/all
CLIST_API_URL=https://clist.by/api/v2/contest/
CLIST_API_KEY=replace-with-clist-key
KAGGLE_API_KEY=replace-with-kaggle-key
KAGGLE_USERNAME=replace-with-kaggle-username

# Sync settings
SYNC_SCHEDULE=0 */6 * * *
SYNC_TIMEOUT=30000
SYNC_RETRIES=3

# Bootstrap admin account
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
